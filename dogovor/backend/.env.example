# БД/хранилище: Postgres + MinIO (российский вариант)
# docker-compose.timeweb.yml поднимает сервисы `postgres` и `minio`

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dogovor
POSTGRES_USER=dogovor
POSTGRES_PASSWORD=dogovor

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket для PDF договоров (создаётся в MinIO при загрузке)
STORAGE_BUCKET=contracts

# CORS (на проде: URL фронта через запятую, без пробелов)
# CORS_ORIGINS=https://dogovor.pyeoptics.com,https://www.pyeoptics.com

# Опционально: wkhtmltopdf в PATH или путь к WeasyPrint
# PDF_ENGINE=weasyprint

# Провайдер почты: smtp (Timeweb/локально) или resend (Railway — SMTP там заблокирован)
# EMAIL_PROVIDER=resend
# EMAIL_PROVIDER=smtp

# SMTP (Яндекс и др.) — при EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=your@mail.com
# SMTP_PASSWORD=app_password
# SMTP_FROM_EMAIL=your@mail.com
# SMTP_FROM_NAME=Пай Оптикс

# Resend (api.resend.com) — при EMAIL_PROVIDER=resend. Бесплатный тир ~100 писем/день.
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_FROM_NAME=Пай Оптикс

# Beorg API (распознавание паспорта РФ: разворот + прописка). Без них эндпоинт /passport/recognize вернёт 503.
# Получить: kyc.beorg.ru/self_sign → Проекты → project_id, token, machine_uid
# BEORG_PROJECT_ID=U_RATE_2
# BEORG_TOKEN=your_token
# BEORG_MACHINE_UID=your_machine_uid
