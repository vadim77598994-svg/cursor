# Supabase (тот же проект или отдельный для договоров)
# Dashboard → Project Settings → API: URL и service_role key
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# Bucket для PDF договоров (создать в Supabase Storage)
SUPABASE_STORAGE_BUCKET=contracts

# CORS (на проде: URL фронта через запятую, без пробелов)
# CORS_ORIGINS=https://dogovor.pyeoptics.com,https://www.pyeoptics.com

# Опционально: wkhtmltopdf в PATH или путь к WeasyPrint
# PDF_ENGINE=weasyprint

# SMTP — отправка PDF на email клиента (опционально; порт 465 = SSL)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=your@mail.com
# SMTP_PASSWORD=app_password
# SMTP_FROM_EMAIL=your@mail.com
# SMTP_FROM_NAME=Пай Оптикс
