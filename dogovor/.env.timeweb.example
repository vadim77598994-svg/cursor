# URL API, который встраивается во фронт на этапе сборки Docker-образа.
# Если фронт и API будут на одном домене через nginx (/api -> backend),
# можно поставить https://dogovor.example.com
# Если API на отдельном поддомене:
# NEXT_PUBLIC_DOGOVOR_API_URL=https://api.dogovor.example.com
NEXT_PUBLIC_DOGOVOR_API_URL=https://api.dogovor.example.com
